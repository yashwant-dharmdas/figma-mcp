    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^4.1.0",
    "tsup": "^8.5.0",
    "bun-types": "^1.3.11"
  }
}
