{
  "name": "@yashwant.dharmdas/figma-mcp",
  "version": "3.0.2",
  "description": "Run Figma MCP locally via npx — connects Claude Desktop directly to your Figma plugin",
  "type": "module",
  "bin": {
    "figma-mcp": "bin/figma-mcp.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "node --watch --experimental-transform-types src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@figma-mcp/shared": "file:../shared",
    "@types/ws": "^8.5.14",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "claude",
    "npx"
  ],
  "license": "MIT"
}
