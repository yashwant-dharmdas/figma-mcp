# ============================================================
# figma-mcp Environment Configuration
# Copy to .env and fill in values
# ============================================================

# ── Relay Server ──────────────────────────────────────────────

RELAY_PORT=3055
RELAY_HOST=0.0.0.0

# HMAC-SHA256 secret for signing channel join tokens.
# REQUIRED in production. Generate with: openssl rand -hex 32
RELAY_SECRET=change-me-in-production

# Set to "disabled" for local development (skips HMAC token validation)
RELAY_AUTH=disabled

# TLS (optional — for WSS without a reverse proxy like nginx)
# If not set, server runs as ws:// (plain WebSocket)
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── MCP Server ────────────────────────────────────────────────

MCP_PORT=3001
MCP_HOST=0.0.0.0

# URL of the relay server. Use ws:// locally, wss:// in production.
# In docker-compose, use the service name: ws://relay:3055
RELAY_URL=ws://localhost:3055

# ── Figma REST API (optional) ─────────────────────────────────
# When set, read-only operations (get_document_info, get_styles, etc.)
# can use the REST API instead of the plugin — faster and cacheable.
# Get yours at: https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=
